# Card content is private (paid layer, future v0.3.0+).
# Full content lives outside the repo at ~/dev/8ball-private/cards.v1.full.js.
# Any cards.v1.js / cards.v*.js / cards.v1.full.js that lands in this repo
# is the secret leaking — gitignore prevents accidental re-add.
content/cards.v*.js
content/cards.*.js
